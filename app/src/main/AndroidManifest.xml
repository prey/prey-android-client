<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.prey"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="internalOnly"
  >

    <uses-feature android:name="android.hardware.location.network" android:required="true" />
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.location" android:required="true" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.camera.flash" android:required="false"/>
    <uses-feature android:name="android.hardware.camera.front" android:required="false"/>

    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove"/>

    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR"/>

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACTION_SHUTDOWN" />

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />


    <!-- This app has permission to register and receive message -->
    <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" />

    <permission android:name="com.prey.permission.C2D_MESSAGE" android:protectionLevel="signature" />

    <uses-permission android:name="com.prey.permission.C2D_MESSAGE" />

    <!-- This app has permission to camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-permission android:name="android.permission.USES_POLICY_FORCE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="true" />

    <application
            android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@drawable/icon"
        android:label="@string/app_name"
        android:supportsRtl = "true"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.AppCompat"
            android:name=".PreyApp">

        <meta-data
            android:name="com.google.android.gms.vision.DEPENDENCIES"
            android:value="barcode" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <meta-data android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

        <meta-data android:name="android.content.APP_RESTRICTIONS"
            android:resource="@xml/app_restrictions" />

        <!-- Exported added for android 12 -->
        <activity
                android:clearTaskOnLaunch="true"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:exported="true"
                android:name=".activities.LoginActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.CloseActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            />

        <activity android:name=".activities.SecurityActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
              />

        <activity android:name=".activities.ReportActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
              />

        <activity android:name=".activities.PreReportActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
             />

        <activity
            android:name=".barcodereader.BarcodeActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            />

        <activity android:name=".barcodereader.BarcodeCaptureActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            />

        <activity
            android:name=".activities.PanelWebActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            android:noHistory="true"
            />

        <activity
            android:name=".activities.WelcomeBatchActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            android:noHistory="true"
            />

        <!-- New Activity for validate token -->
        <activity
            android:name=".activities.SplashBatchActivity"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
            android:noHistory="true"
            />

        <activity
                android:windowSoftInputMode="stateHidden|adjustResize"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.CheckPasswordHtmlActivity" />

        <activity
                android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:finishOnTaskLaunch="true"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoTitleBar"
                android:name=".activities.PreyConfigurationActivity" />
        <activity

                android:clearTaskOnLaunch="true"
            android:noHistory = "true"
            android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:launchMode="singleTask"
                android:name=".activities.PopUpAlertActivity" />
        <activity
                android:clearTaskOnLaunch="true"
            android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:launchMode="singleTask"
                android:name=".activities.CameraActivity" />
        <activity
                android:theme="@style/Theme.Transparent"
            android:windowSoftInputMode="stateHidden|adjustResize"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.SimpleCameraActivity" />

        <activity
                android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.PermissionInformationActivity" />

        <activity
                android:launchMode="singleInstance"
            android:noHistory="true"
            android:windowSoftInputMode="stateHidden|adjustResize"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.PasswordNativeActivity" />
        <activity
                android:launchMode="singleInstance"
            android:noHistory="true"
            android:windowSoftInputMode="stateHidden|adjustResize"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.PasswordHtmlActivity" />
        <activity
                android:launchMode="singleInstance"
            android:noHistory="true"
            android:windowSoftInputMode="stateHidden|adjustResize"
            android:configChanges="keyboardHidden|orientation"
            android:screenOrientation="portrait"
                android:name=".activities.OpenSettingsActivity" />

        <!-- Exported added for android 12 -->
        <receiver
                android:enabled="true"
            android:exported="true"
            android:label="PreyBootController"
                android:name=".receivers.PreyBootController">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Exported added for android 12 -->
        <receiver
                android:exported="true"
                android:name=".events.receivers.EventReceiver">
            <intent-filter android:priority="20000">

                <!-- TURNED ON/OFF -->

                <action android:name="android.intent.action.ACTION_SHUTDOWN" />

                <action android:name="android.intent.action.QUICKBOOT_POWEROFF" />

                <!-- BATTERY LOW -->

                <action android:name="android.intent.action.BATTERY_LOW" />

                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />

                <!--   BOOT COMPLETED -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />

                <action android:name="android.location.MODE_CHANGED" />

                <action android:name="android.location.PROVIDERS_CHANGED" />

                <action android:name="android.intent.action.SIM_STATE_CHANGED" />

                <action android:name="android.os.action.POWER_SAVE_MODE_CHANGED"/>

                <action android:name="android.intent.action.ACTION_REQUEST_SHUTDOWN"/>

                <action android:name="android.intent.action.USER_PRESENT"/>

            </intent-filter>

        </receiver>

        <receiver android:name=".receivers.AlarmReportReceiver" />
        <receiver android:name=".actions.aware.AlarmAwareReceiver" />
        <receiver android:name=".receivers.AlarmScheduledReceiver" />
        <receiver android:name=".actions.location.daily.AlarmLocationReceiver" />

        <receiver
                android:exported="true"
                android:name=".receivers.GeofenceReceiver">
            <intent-filter>
                <action android:name="android.location.MODE_CHANGED" />
                <action android:name="android.location.PROVIDERS_CHANGED" />
            </intent-filter>
        </receiver>
        <receiver
                android:exported="true"
                android:name=".receivers.AwareGeofenceReceiver">
            <intent-filter>
                <action android:name="android.location.MODE_CHANGED" />
                <action android:name="android.location.PROVIDERS_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Exported added for android 12 -->
        <receiver
                android:label="@string/device_admin_label"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
                android:name=".receivers.PreyDeviceAdmin">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/security_policies" />

            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <receiver android:name=".actions.autoconnect.AutoConnectAlarmReceiver" />

        <receiver android:name=".actions.alert.AlertReceiver" />
        <receiver android:name=".actions.triggers.TimeTriggerReceiver" />

        <!-- Services -->
        <service android:name=".services.LocationService" />
        <service android:name=".actions.location.LocationUpdatesService" />
        <service android:name=".services.PreyBootService" />
        <service android:name=".services.PreyRunnerService" />
        <service android:name=".beta.services.PreyBetaRunnerService" />
        <service android:name=".actions.report.ReportService" />
        <service android:name=".actions.geofences.GeofenceIntentService" />
        <service android:name=".actions.aware.AwareIntentService" />
        <service android:name=".actions.fileretrieval.FileretrievalService" />
        <service android:name=".services.PreyLockService" />
        <service android:name=".services.PreyLockHtmlService" />
        <service android:name=".services.CheckLockActivated" />
        <service android:name=".services.PreyOverlayService" />


        <service android:name=".services.PreyNotificationForeGroundService" />

        <service android:name=".actions.autoconnect.AutoConnectService" />

        <service android:name=".services.ActivityIntentService" />

        <receiver android:name=".receivers.AlarmDisablePowerReceiver" />

        <!-- Exported added for android 12 -->
        <receiver
                android:enabled="true"
            android:exported="true"
                android:name=".receivers.PreyDisablePowerOptionsReceiver">
            <intent-filter android:priority="20000">
                <action android:name="android.intent.action.CLOSE_SYSTEM_DIALOGS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!--
            BroadcastReceiver that listens for changes in application restrictions.
        -->
        <receiver
                android:enabled="true"
            android:exported="true"
                android:name=".receivers.RestrictionsReceiver">
            <!--
                Intent filter that specifies the action this receiver is interested in.
                In this case, it's the APPLICATION_RESTRICTIONS_CHANGED action, which
                is broadcast when the application restrictions have changed.
            -->
            <intent-filter>
                <action android:name="android.content.action.APPLICATION_RESTRICTIONS_CHANGED"/>
            </intent-filter>
        </receiver>

        <service android:name=".services.PreyDisablePowerOptionsService" />
        <service android:name=".services.PreySecureService" />

        <!-- Exported added for android 12 -->
        <!-- [START firebase_service] -->
        <service
                android:exported="true"
                android:name=".services.MyFirebaseMessagingService">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>
        <!-- [END firebase_service] -->

        <service
                android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true"
                android:name=".services.PreyJobService" />

        <service
                android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true"
                android:name=".services.AwareJobService" />

        <service
                android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true"
                android:name=".services.AutoconnectJobService" />

        <service
                android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true"
                android:name=".services.ReportJobService" />

        <service android:name=".services.PreyAccessibilityService" />
        <service android:name=".services.PreyStorageService" />
        <service android:name=".services.PreyPermissionService" />
        <service android:name=".services.PreyCloseNotificationService" />

        <!-- Exported added for android 12 -->
        <service
                android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:enabled="true"
            android:exported="true"
                android:name=".services.AppAccessibilityService">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" android:resource="@xml/accessibilityservice"/>
        </service>

        <activity
            android:name=".activities.SplashMdmActivity"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme" />

    </application>

</manifest>
